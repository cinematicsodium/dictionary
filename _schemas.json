    {
        "id": "ja-00047",
        "headword": "木漏れ日",
        "romanization": "komorebi",
        "ipa_transcription": "ko̞mo̞ɾe̞bi",
        "language": {
            "code": "ja",
            "name": "Japanese",
            "family": "Japonic"
        },
        "part_of_speech": "noun",
        "morphology": {
            "root": "漏れ (more, 'to leak')",
            "prefix": "木 (ko, 'tree')",
            "suffix": "日 (bi, 'sunlight')",
            "inflection_class": null,
            "plural_form": null
        },
        "definitions": [
            {
                "sense_number": 1,
                "definition": "Sunlight filtering through the leaves of trees",
                "semantic_domain": "nature/light"
            },
            {
                "sense_number": 2,
                "definition": "The interplay of light and shadow created by sunlight shining through foliage",
                "semantic_domain": "aesthetics/nature"
            }
        ],
        "grammar": {
            "gender": null,
            "number": "uncountable",
            "case_system": "marked by particles (が, を, の, etc.)",
            "verb_transitivity": null,
            "conjugation_class": null
        },
        "etymology": {
            "origin_language": "Japanese (native compound)",
            "origin_word": "木 (ki/ko) + 漏れ (more) + 日 (hi/bi)",
            "derivation": "compound noun formed by combining 'tree,' 'leaking,' and 'sun/day'",
            "notes": "Rendaku (sequential voicing) changes hi to bi in the compound"
        },
        "usage": {
            "register": "literary/poetic",
            "frequency": "low-to-moderate",
            "region": "all regions of Japan",
            "notes": "Often cited as an example of an 'untranslatable' Japanese word; popular in haiku and nature writing"
        },
        "examples": [
            {
                "sentence": "公園で木漏れ日を浴びながら読書した。",
                "romanization": "Kouen de komorebi wo abinagara dokusho shita.",
                "translation": "I read a book while basking in the sunlight filtering through the trees in the park.",
                "source": "Constructed example"
            },
            {
                "sentence": "森の中の木漏れ日が美しかった。",
                "romanization": "Mori no naka no komorebi ga utsukushikatta.",
                "translation": "The dappled sunlight inside the forest was beautiful.",
                "source": "Constructed example"
            }
        ],
        "synonyms": [
            "日だまり (hidamari, 'sunny spot')",
            "木洩れ陽 (komorebi, 'alternate kanji spelling')"
        ],
        "antonyms": [],
        "related_words": [
            {
                "word": "木陰 (kokage)",
                "relationship": "semantically related — 'tree shade'"
            },
            {
                "word": "日差し (hizashi)",
                "relationship": "hypernym — 'sunlight/sunshine' in general"
            }
        ],
        "collocations": [
            "木漏れ日が差す (komorebi ga sasu — 'dappled light shines through')",
            "木漏れ日を浴びる (komorebi wo abiru — 'to bathe in dappled light')"
        ],
        "pronunciation_notes": "Four morae: ko-mo-re-bi. Pitch accent is flat (heiban) in standard Tokyo dialect.",
